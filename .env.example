# Copy this file to .env and fill in only the keys you plan to use.
# Do not commit .env.

# LLM providers for narrow semantic judge calls.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Search / extraction providers. Optional if callers pass pre-fetched results.
SERPER_API_KEY=
JINA_API_KEY=

# Optional financial and macro data providers.
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
FMP_API_KEY=
FRED_API_KEY=
MARKETSTACK_API_KEY=
TIINGO_API_KEY=

# SEC does not require an API key, but requests should include a clear user agent.
# Example: "Your Name your.email@example.com"
SEC_USER_AGENT=

# Optional runtime settings.
# Default is auto: use OpenAI/Anthropic if both key and model are configured;
# otherwise fall back to the local heuristic judge.
CREDIBILITY_LLM_PROVIDER=auto
OPENAI_MODEL=
ANTHROPIC_MODEL=
CREDIBILITY_LIVE_EXTRACTION=false
CREDIBILITY_STRUCTURED_SOURCES=true
CREDIBILITY_YAHOO_FALLBACK=false
CREDIBILITY_ALLOW_INSECURE_SSL_FALLBACK=false
CREDIBILITY_REQUEST_TIMEOUT=25
